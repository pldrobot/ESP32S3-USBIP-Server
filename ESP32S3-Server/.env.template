# =============================================================
# ESP32-S3 USB/IP Bridge — Configuration Template
#
# 1. Copy this file to .env
#    cp .env.template .env
#
# 2. Fill in the values below for your setup.
#
# 3. Run 'pio run' — src/config_env.h is generated automatically.
#
# .env is gitignored and never committed to source control.
# =============================================================

# ---- USB Device (informational — shown in logs/dashboard) ----
# VID/PID are read automatically from the USB descriptor at runtime;
# these values are only used as labels in the startup log.
# Find them in Device Manager > Universal Serial Bus controllers
# when the printer is connected to a PC directly.
USB_DEVICE_VID=0x0000
USB_DEVICE_PID=0x0000

# ---- AP Mode (first-time WiFi setup) ----
# The ESP32 broadcasts this SSID when no WiFi credentials are saved.
# Connect to it and open http://192.168.4.1 to configure your network.
AP_SSID="USB-Bridge-Setup"
AP_PASSWORD="12345678"

# ---- Network ----
# mDNS hostname — device appears as <MDNS_HOSTNAME>.lan on your LAN.
MDNS_HOSTNAME="usbip-bridge"

# Human-readable device label shown in the startup log.
DEVICE_NAME="USB Printer Bridge"

# ---- OTA (Over-the-Air firmware updates) ----
# Must match the MDNS_HOSTNAME (or use IP) for the upload target.
OTA_HOSTNAME="usbip-bridge"
OTA_PASSWORD="changeme"

# ---- Hardware ----
# GPIO pin connected to the status LED.
# 2 = onboard LED on most ESP32-S3 DevKit-C boards.
LED_PIN=2

# ---- NVS Storage ----
# Namespace used to store WiFi credentials in flash.
# Change only if you need to isolate credential namespaces between devices.
NVS_NAMESPACE="usbipsrv"
